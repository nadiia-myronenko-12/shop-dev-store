<site-header class="site-header">
  <div class="site-header__bar">
    <a href="{{ routes.root_url }}" class="site-header__logo">
      {{- shop.name -}}
    </a>

    <nav class="site-header__nav" aria-label="Main navigation">
      {%- for link in section.settings.menu.links -%}
        <a
          href="{{ link.url }}"
          class="site-header__nav-link{%- if link.active %} site-header__nav-link--active{%- endif -%}">
          {{- link.title -}}
        </a>
      {%- endfor -%}
    </nav>

    <div class="site-header__actions">
      {%- if shop.customer_accounts_enabled -%}
        <shopify-account menu="{{ section.settings.customer_account_menu }}">
          <a href="{{ routes.account_url }}" class="site-header__icon-btn" aria-label="Account">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </a>
        </shopify-account>
      {%- endif -%}

      <a
        href="{{ routes.cart_url }}"
        class="site-header__icon-btn site-header__cart-btn"
        aria-label="Cart, {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span
          class="site-header__cart-badge"
          aria-hidden="true"
          data-count="{{ cart.item_count }}">{{ cart.item_count }}</span>
      </a>

      <button
        class="site-header__icon-btn site-header__hamburger"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="site-mobile-nav">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="site-header__drawer" id="site-mobile-nav" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Navigation">
    <div class="site-header__drawer-panel">
      <div class="site-header__drawer-top">
        <a href="{{ routes.root_url }}" class="site-header__logo" tabindex="-1">
          {{- shop.name -}}
        </a>
        <button class="site-header__icon-btn site-header__drawer-close" aria-label="Close navigation menu">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <nav class="site-header__drawer-nav" aria-label="Mobile navigation">
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}" class="site-header__drawer-link" tabindex="-1">
            {{- link.title -}}
          </a>
        {%- endfor -%}
      </nav>
    </div>
    <div class="site-header__drawer-backdrop"></div>
  </div>
</site-header>

{% stylesheet %}
  site-header {
    display: block;
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid #DCDCDC;
    font-family: 'Inter', sans-serif;
  }

  .site-header__bar {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 16px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .site-header__logo {
    font-size: 18px;
    font-weight: 700;
    color: #000;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Desktop nav ── */
  .site-header__nav {
    display: none;
    align-items: center;
    gap: 2px;
    flex: 1;
    justify-content: center;
  }

  .site-header__nav-link {
    font-size: 14px;
    font-weight: 500;
    color: #535353;
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 8px;
    transition: color 0.2s ease, background-color 0.2s ease;
    white-space: nowrap;
  }

  .site-header__nav-link:hover,
  .site-header__nav-link--active {
    color: #000;
    background-color: #F8F8F8;
  }

  /* ── Icon buttons (shared) ── */
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }

  .site-header__icon-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    color: #000;
    text-decoration: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .site-header__icon-btn:hover {
    background-color: #F8F8F8;
  }

  /* ── Cart badge ── */
  .site-header__cart-badge {
    display: none;
    position: absolute;
    top: 5px;
    right: 5px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    background: #E41616;
    color: #fff;
    font-size: 10px;
    font-weight: 600;
    border-radius: 8px;
    align-items: center;
    justify-content: center;
    line-height: 1;
    pointer-events: none;
  }

  .site-header__cart-badge:not([data-count="0"]) {
    display: flex;
  }

  /* ── Mobile drawer ── */
  .site-header__drawer {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    pointer-events: none;
    visibility: hidden;
  }

  .site-header__drawer[aria-hidden="false"] {
    pointer-events: auto;
    visibility: visible;
  }

  .site-header__drawer-panel {
    position: relative;
    width: 280px;
    max-width: 85vw;
    height: 100%;
    background: #fff;
    display: flex;
    flex-direction: column;
    z-index: 1;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    overflow-y: auto;
  }

  .site-header__drawer[aria-hidden="false"] .site-header__drawer-panel {
    transform: translateX(0);
  }

  .site-header__drawer-backdrop {
    flex: 1;
    background: rgba(0, 0, 0, 0.4);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .site-header__drawer[aria-hidden="false"] .site-header__drawer-backdrop {
    opacity: 1;
  }

  .site-header__drawer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid #DCDCDC;
    flex-shrink: 0;
  }

  .site-header__drawer-nav {
    display: flex;
    flex-direction: column;
    padding: 12px 8px;
    gap: 2px;
    flex: 1;
  }

  .site-header__drawer-link {
    display: block;
    font-size: 16px;
    font-weight: 500;
    color: #000;
    text-decoration: none;
    padding: 12px 12px;
    border-radius: 8px;
    transition: background-color 0.2s ease;
  }

  .site-header__drawer-link:hover {
    background-color: #F8F8F8;
  }

  /* ── Desktop breakpoint ── */
  @media (min-width: 768px) {
    .site-header__bar {
      padding: 0 24px;
      height: 72px;
    }

    .site-header__nav {
      display: flex;
    }

    .site-header__hamburger {
      display: none;
    }
  }

  @media (min-width: 1440px) {
    .site-header__bar {
      padding: 0 48px;
    }
  }
{% endstylesheet %}

{% javascript %}
  class SiteHeader extends HTMLElement {
    connectedCallback() {
      this.hamburger = this.querySelector('.site-header__hamburger');
      this.closeBtn = this.querySelector('.site-header__drawer-close');
      this.drawer = this.querySelector('.site-header__drawer');
      this.backdrop = this.querySelector('.site-header__drawer-backdrop');
      this.drawerLinks = this.querySelectorAll('.site-header__drawer-link');

      this.hamburger?.addEventListener('click', () => this.openDrawer());
      this.closeBtn?.addEventListener('click', () => this.closeDrawer());
      this.backdrop?.addEventListener('click', () => this.closeDrawer());
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') this.closeDrawer();
      });
    }

    openDrawer() {
      this.drawer.setAttribute('aria-hidden', 'false');
      this.hamburger.setAttribute('aria-expanded', 'true');
      this.drawerLinks.forEach(link => link.removeAttribute('tabindex'));
      document.body.style.overflow = 'hidden';
      this.closeBtn?.focus();
    }

    closeDrawer() {
      if (this.drawer.getAttribute('aria-hidden') === 'true') return;
      this.drawer.setAttribute('aria-hidden', 'true');
      this.hamburger.setAttribute('aria-expanded', 'false');
      this.drawerLinks.forEach(link => link.setAttribute('tabindex', '-1'));
      document.body.style.overflow = '';
      this.hamburger?.focus();
    }
  }

  customElements.define('site-header', SiteHeader);
{% endjavascript %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
