{% stylesheet %}
  .hero {
    grid-column: 1 / -1;
    background-color: #F8F8F8;
    padding: 64px var(--page-margin);
    font-family: 'Inter'
    , sans-serif;
  }

  .hero__inner {
    max-width: var(--content-width, 1200px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero__label {
    display: block;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9D9D9D;
    margin-bottom: 16px;
    animation: hero-fade-up 0.5s ease both;
    animation-delay: 0s;
  }

  .hero__heading {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.05;
    color: #000;
    margin-bottom: 20px;
    white-space: pre-line;
    animation: hero-fade-up 0.5s ease both;
    animation-delay: 0.1s;
  }

  .hero__subheading {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.7;
    color: #535353;
    margin-bottom: 36px;
    max-width: 460px;
    animation: hero-fade-up 0.5s ease both;
    animation-delay: 0.2s;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    animation: hero-fade-up 0.5s ease both;
    animation-delay: 0.3s;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    border-radius: 8px;
    font-family: 'Inter'
    , sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
    border: 2px solid #000;
  }

  .hero__btn:hover {
    opacity: 0.75;
  }

  .hero__btn--primary {
    background: #000;
    color: #fff;
  }

  .hero__btn--secondary {
    background: transparent;
    color: #000;
  }

  .hero__media {
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: #DCDCDC;
    animation: hero-fade-up 0.5s ease both;
    animation-delay: 0.15s;
  }

  .hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero__media svg {
    width: 100%;
    height: 100%;
    opacity: 0.25;
  }

  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 768px) {
    .hero {
      padding: 80px var(--page-margin);
    }

    .hero__inner {
      grid-template-columns: 1fr 1fr;
    }

    .hero__heading {
      font-size: 56px;
    }
  }

  @media (min-width: 1440px) {
    .hero {
      padding: 120px var(--page-margin);
    }

    .hero__heading {
      font-size: 72px;
    }

    .hero__subheading {
      font-size: 18px;
    }
  }
{% endstylesheet %}

<div class="hero">
  <div class="hero__inner">
    <div class="hero__content">
      {%- if section.settings.label != blank -%}
        <p class="hero__label">{{ section.settings.label }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="hero__ctas">
        {%- if section.settings.cta_primary_text != blank -%}
          <a href="{{ section.settings.cta_primary_url | default: '#' }}" class="hero__btn hero__btn--primary">
            {{ section.settings.cta_primary_text }}
          </a>
        {%- endif -%}

        {%- if section.settings.cta_secondary_text != blank -%}
          <a href="{{ section.settings.cta_secondary_url | default: '#' }}" class="hero__btn hero__btn--secondary">
            {{ section.settings.cta_secondary_text }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="hero__media">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'eager', widths: '400, 600, 900', sizes: '(min-width: 768px) 50vw, 100vw', fetchpriority: 'high'
        }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag }}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Hero",
    "tag": "section",
    "class": "section-hero",
    "settings": [
      {
        "type": "text",
        "id": "label",
        "label": "Label",
        "default": "New Collection · 2026"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Wear What\nYou Believe In"
      },
      {
        "type": "textarea",
        "id": "subheading",
        "label": "Subheading",
        "default": "Mindful jewelry crafted for the ones who lead with intention."
      },
      {
        "type": "text",
        "id": "cta_primary_text",
        "label": "Primary button text",
        "default": "Shop Now"
      }, {
        "type": "url",
        "id": "cta_primary_url",
        "label": "Primary button link"
      }, {
        "type": "text",
        "id": "cta_secondary_text",
        "label": "Secondary button text",
        "default": "View Collections"
      }, {
        "type": "url",
        "id": "cta_secondary_url",
        "label": "Secondary button link"
      }, {
        "type": "image_picker",
        "id": "image",
        "label": "Hero image"
      }
    ],
    "presets": [
      {
        "name": "Hero",
        "settings": {
          "label": "New Collection · 2026",
          "heading": "Wear What You Believe In",
          "subheading": "Mindful jewelry crafted for the ones who lead with intention.",
          "cta_primary_text": "Shop Now",
          "cta_secondary_text": "View Collections"
        }
      }
    ]
  }
{% endschema %}