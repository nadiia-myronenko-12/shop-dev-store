{% stylesheet %}
  .site-footer {
    grid-column: 1 / -1;
    background-color: #000;
    font-family: 'Inter', sans-serif;
    padding: 48px var(--page-margin) 24px;
  }

  .site-footer__inner {
    max-width: var(--content-width, 1200px);
    margin: 0 auto;
  }

  .site-footer__newsletter {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .site-footer__newsletter-heading {
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
  }

  .site-footer__newsletter-subheading {
    font-size: 13px;
    font-weight: 400;
    color: #9d9d9d;
    margin-top: 4px;
  }

  .site-footer__newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-start;
  }

  .site-footer__newsletter-input {
    width: 100%;
    padding: 12px 16px;
    border-radius: 8px;
    border: 1px solid #535353;
    background: transparent;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .site-footer__newsletter-input::placeholder {
    color: #9d9d9d;
  }

  .site-footer__newsletter-input:focus {
    border-color: #fff;
  }

  .site-footer__newsletter-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
    border: 2px solid #000;
  }

  .site-footer__newsletter-success {
    display: none;
    font-size: 13px;
    color: #9d9d9d;
  }

  .site-footer__newsletter-form[data-submitted] .site-footer__newsletter-success {
    display: block;
  }

  .site-footer__newsletter-form[data-submitted] .site-footer__newsletter-input,
  .site-footer__newsletter-form[data-submitted] .site-footer__newsletter-submit {
    display: none;
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    padding-bottom: 32px;
  }

  .site-footer__brand-name {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
  }

  .site-footer__tagline {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.6;
    color: #9d9d9d;
    margin-top: 12px;
    max-width: 360px;
  }

  .site-footer__socials {
    display: flex;
    gap: 8px;
    margin-top: 20px;
  }

  .site-footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: #fff;
    background-color: rgba(255, 255, 255, 0.08);
    transition: background-color 0.2s ease;
  }

  .site-footer__nav-title {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #9d9d9d;
    margin-bottom: 16px;
  }

  .site-footer__nav-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .site-footer__nav-link {
    font-size: 14px;
    font-weight: 400;
    color: #dcdcdc;
    text-decoration: none;
    transition: color 0.2s ease;
    width: fit-content;
  }

  .site-footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .site-footer__copyright {
    font-size: 13px;
    color: #9d9d9d;
  }

  .site-footer__copyright a {
    color: #9d9d9d;
    text-decoration: underline;
  }

  .site-footer__payment {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .site-footer__payment svg {
    height: 24px;
    width: auto;
    border-radius: 4px;
  }

  @media (hover: hover) and (pointer: fine) {
    .site-footer__social-link:hover {
      background-color: rgba(255, 255, 255, 0.16);
    }

    .site-footer__nav-link:hover {
      color: #fff;
    }
  }

  @media (min-width: 768px) {
    .site-footer {
      padding: 64px var(--page-margin) 32px;
    }

    .site-footer__newsletter {
      padding-top: 0;
      border-top: none;
    }

    .site-footer__top {
      grid-template-columns: 1.4fr 1fr 1.4fr;
      gap: 24px;
    }

    .site-footer__bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  @media (min-width: 1440px) {
    .site-footer {
      padding: 80px var(--page-margin) 32px;
    }
  }
{% endstylesheet %}

<site-footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <div class="site-footer__brand">
        <a href="{{ routes.root_url }}" class="site-footer__brand-name">{{ shop.name }}</a>

        {%- if section.settings.tagline != blank -%}
          <p class="site-footer__tagline">{{ section.settings.tagline | escape }}</p>
        {%- endif -%}

        {%- if section.settings.social_instagram != blank
          or section.settings.social_facebook != blank
          or section.settings.social_tiktok != blank
          or section.settings.social_x != blank
        -%}
          <div class="site-footer__socials">
            {%- if section.settings.social_instagram != blank -%}
              <a
                href="{{ section.settings.social_instagram }}"
                class="site-footer__social-link"
                aria-label="Instagram"
                target="_blank"
                rel="noopener"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.917 3.917 0 0 0-1.417.923A3.927 3.927 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.916 3.916 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.926 3.926 0 0 0-.923-1.417A3.911 3.911 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0h.003Zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599.28.28.453.546.598.92.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.47 2.47 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.478 2.478 0 0 1-.92-.598 2.48 2.48 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233 0-2.136.008-2.388.046-3.231.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92.28-.28.546-.453.92-.598.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045v.002Zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92Zm-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217Zm0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334Z"/>
                </svg>
              </a>
            {%- endif -%}

            {%- if section.settings.social_facebook != blank -%}
              <a
                href="{{ section.settings.social_facebook }}"
                class="site-footer__social-link"
                aria-label="Facebook"
                target="_blank"
                rel="noopener"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0 0 3.603 0 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951Z"/>
                </svg>
              </a>
            {%- endif -%}

            {%- if section.settings.social_tiktok != blank -%}
              <a
                href="{{ section.settings.social_tiktok }}"
                class="site-footer__social-link"
                aria-label="TikTok"
                target="_blank"
                rel="noopener"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M9 0h1.98c.144.715.54 1.617 1.235 2.512C12.895 3.389 13.797 4 15 4v2c-1.753 0-3.07-.814-4-1.829V11a5 5 0 1 1-5-5v2a3 3 0 1 0 3 3V0Z"/>
                </svg>
              </a>
            {%- endif -%}

            {%- if section.settings.social_x != blank -%}
              <a
                href="{{ section.settings.social_x }}"
                class="site-footer__social-link"
                aria-label="X"
                target="_blank"
                rel="noopener"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865Z"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.menu.links.size > 0 -%}
        <div class="site-footer__nav">
          {%- if section.settings.nav_title != blank -%}
            <p class="site-footer__nav-title">{{ section.settings.nav_title | escape }}</p>
          {%- endif -%}

          <nav class="site-footer__nav-links" aria-label="Footer navigation">
            {%- for link in section.settings.menu.links -%}
              <a href="{{ link.url }}" class="site-footer__nav-link">{{ link.title | escape }}</a>
            {%- endfor -%}
          </nav>
        </div>
      {%- endif -%}

      {%- if section.settings.show_newsletter -%}
        <div class="site-footer__newsletter">
          <div class="site-footer__newsletter-text">
            {%- if section.settings.newsletter_heading != blank -%}
              <p class="site-footer__newsletter-heading">
                {{ section.settings.newsletter_heading | escape }}
              </p>
            {%- endif -%}
            {%- if section.settings.newsletter_subheading != blank -%}
              <p class="site-footer__newsletter-subheading">
                {{ section.settings.newsletter_subheading | escape }}
              </p>
            {%- endif -%}
          </div>

          {%- form 'customer', class: 'site-footer__newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input
              type="email"
              name="contact[email]"
              class="site-footer__newsletter-input"
              placeholder="{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}"
              required
              autocomplete="email"
            >
            <button type="submit" class="site-footer__newsletter-submit">
              {{ section.settings.newsletter_button_label | default: 'Subscribe' }}
            </button>
            <p class="site-footer__newsletter-success">
              {{ section.settings.newsletter_success_message | default: 'Thanks for subscribing!' }}
            </p>
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }}
        {{ shop.name | link_to: routes.root_url }}, {{ powered_by_link }}
      </p>

      {%- if section.settings.show_payment_icons -%}
        <div class="site-footer__payment">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</site-footer>

{% javascript %}
  class SiteFooter extends HTMLElement {
    connectedCallback() {
      this.addEventListener('submit', (event) => {
        const form = event.target.closest('.site-footer__newsletter-form');
        if (!form) return;
        event.preventDefault();
        this.submitNewsletter(form);
      });
    }

    async submitNewsletter(form) {
      try {
        const response = await fetch(form.action, { method: 'POST', body: new FormData(form) });
        if (response.ok) form.setAttribute('data-submitted', '');
      } catch {
        form.submit();
      }
    }
  }

  customElements.define('site-footer', SiteFooter);
{% endjavascript %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Heading",
      "default": "Stay in the Loop"
    },
    {
      "type": "text",
      "id": "newsletter_subheading",
      "label": "Subheading",
      "default": "New arrivals, exclusive deals & more."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Input placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "newsletter_button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "newsletter_success_message",
      "label": "Success message",
      "default": "Thanks for subscribing!"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Mindful jewelry crafted for the ones who lead with intention."
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "text",
      "id": "nav_title",
      "label": "Menu title",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok"
    },
    {
      "type": "url",
      "id": "social_x",
      "label": "X"
    },
    {
      "type": "header",
      "content": "Payment"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
