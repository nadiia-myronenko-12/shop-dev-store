{% stylesheet %}
  .newsletter {
    grid-column: 1 / -1;
    background: #000;
    padding: 80px var(--page-margin);
    font-family: 'Inter', sans-serif;
  }

  .newsletter__inner {
    max-width: var(--content-width, 600px);
    margin: 0 auto;
    text-align: center;
  }

  .newsletter__heading {
    font-size: 32px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 12px;
    line-height: 1.15;
  }

  .newsletter__subheading {
    font-size: 15px;
    font-weight: 400;
    color: #9D9D9D;
    margin-bottom: 36px;
  }

  .newsletter__form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 480px;
    margin: 0 auto;
  }

  .newsletter__input {
    padding: 14px 18px;
    border-radius: 8px;
    border: 1px solid #535353;
    background: transparent;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .newsletter__input::placeholder {
    color: #9D9D9D;
  }

  .newsletter__input:focus {
    border-color: #fff;
  }

  .newsletter__submit {
    padding: 14px 28px;
    border-radius: 8px;
    background: #fff;
    color: #000;
    border: none;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .newsletter__submit:hover {
    opacity: 0.85;
  }

  .newsletter__success {
    display: none;
    font-size: 14px;
    color: #9D9D9D;
    margin-top: 4px;
  }

  .newsletter__form[data-submitted] .newsletter__success {
    display: block;
  }

  .newsletter__form[data-submitted] .newsletter__input,
  .newsletter__form[data-submitted] .newsletter__submit {
    display: none;
  }

  @media (min-width: 768px) {
    .newsletter__form {
      flex-direction: row;
    }

    .newsletter__input {
      flex: 1;
    }

    .newsletter__heading {
      font-size: 40px;
    }
  }
{% endstylesheet %}

<div class="newsletter">
  <div class="newsletter__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="newsletter__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="newsletter__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- form 'customer', class: 'newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input
        type="email"
        name="contact[email]"
        class="newsletter__input"
        placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}"
        required
        autocomplete="email">
      <button type="submit" class="newsletter__submit">
        {{ section.settings.button_label | default: 'Subscribe' }}
      </button>
      <p class="newsletter__success">{{ section.settings.success_message | default: 'Thanks for subscribing!' }}</p>
    {%- endform -%}
  </div>
</div>

{% javascript %}
  document.querySelectorAll('.newsletter__form').forEach(function(form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
        });
        if (res.ok) {
          form.setAttribute('data-submitted', '');
        }
      } catch {
        form.submit();
      }
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay in the Loop"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "New arrivals, exclusive deals & more."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for subscribing!"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
