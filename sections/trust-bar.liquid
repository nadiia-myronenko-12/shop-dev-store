{% stylesheet %}
  .trust-bar {
    grid-column: 1 / -1;
    background: #fff;
    border-top: 1px solid #DCDCDC;
    border-bottom: 1px solid #DCDCDC;
    padding: 20px var(--page-margin);
    font-family: 'Inter', sans-serif;
  }

  .trust-bar__inner {
    max-width: var(--content-width, 1200px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px 16px;
  }

  .trust-bar__item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .trust-bar__icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: #000;
  }

  .trust-bar__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .trust-bar__text {
    font-size: 13px;
    font-weight: 400;
    color: #535353;
    line-height: 1.4;
  }

  @media (min-width: 768px) {
    .trust-bar {
      padding: 24px var(--page-margin);
    }

    .trust-bar__inner {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
  }
{% endstylesheet %}

<div class="trust-bar">
  <div class="trust-bar__inner">
    {%- for block in section.blocks -%}
      <div class="trust-bar__item" {{ block.shopify_attributes }}>
        <div class="trust-bar__icon" aria-hidden="true">
          {%- case block.settings.icon -%}
            {%- when 'shipping' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13" rx="1"/>
                <path d="M16 8h4l3 3v5h-7V8z"/>
                <circle cx="5.5" cy="18.5" r="2.5"/>
                <circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            {%- when 'star' -%}
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {%- when 'returns' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 .49-3.88"/>
              </svg>
            {%- when 'lock' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
          {%- endcase -%}
        </div>
        <span class="trust-bar__text">{{ block.settings.text }}</span>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "class": "section-trust-bar",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping" },
            { "value": "star", "label": "Star / Review" },
            { "value": "returns", "label": "Returns" },
            { "value": "lock", "label": "Secure" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping on $50+"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "item", "settings": { "icon": "shipping", "text": "Free shipping on orders $50+" } },
        { "type": "item", "settings": { "icon": "star", "text": "4.9★  —  2,000+ reviews" } },
        { "type": "item", "settings": { "icon": "returns", "text": "30-day easy returns" } },
        { "type": "item", "settings": { "icon": "lock", "text": "Secure checkout" } }
      ]
    }
  ]
}
{% endschema %}
