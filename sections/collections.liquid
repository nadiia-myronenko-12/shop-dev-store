{% comment %}
  This section is used in the list-collections template to render a list of
  collections.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/collection
{% endcomment %}

{% stylesheet %}
  .collections-page {
    grid-column: 1 / -1;
    padding: 64px var(--page-margin);
    font-family: 'Inter', sans-serif;
    background-color: #ffffff;
  }

  .collections-page__inner {
    max-width: var(--content-width, 1200px);
    margin: 0 auto;
  }

  .collections-page__header {
    margin-bottom: 40px;
  }

  .collections-page__label {
    display: block;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9d9d9d;
    margin-bottom: 8px;
  }

  .collections-page__title {
    font-size: 32px;
    font-weight: 700;
    color: #000;
    line-height: 1.15;
    margin-bottom: 12px;
  }

  .collections-page__subheading {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.7;
    color: #535353;
    max-width: 560px;
  }

  .collections-page__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .collections-page__card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: #dcdcdc;
    display: block;
    text-decoration: none;
  }

  .collections-page__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .collections-page__card svg {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.25;
    transition: transform 0.5s ease;
  }

  .collections-page__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, transparent 55%);
    transition: opacity 0.3s ease;
  }

  .collections-page__card:hover .collections-page__card-overlay {
    opacity: 0.85;
  }

  .collections-page__card-name {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    line-height: 1.2;
  }

  .collections-page__empty {
    font-size: 16px;
    color: #535353;
  }

  @media (min-width: 768px) {
    .collections-page {
      padding: 80px var(--page-margin);
    }

    .collections-page__title {
      font-size: 40px;
    }

    .collections-page__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media (min-width: 1440px) {
    .collections-page {
      padding: 100px var(--page-margin);
    }

    .collections-page__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .collections-page__card:hover img,
    .collections-page__card:hover svg {
      transform: scale(1.04);
    }
  }

  @media (hover: none) and (pointer: coarse) {
    .collections-page__card:active img,
    .collections-page__card:active svg {
      transform: scale(1.04);
    }
  }
{% endstylesheet %}

<div class="collections-page">
  <div class="collections-page__inner">
    <div class="collections-page__header">
      {%- if section.settings.label != blank -%}
        <p class="collections-page__label">{{ section.settings.label | escape }}</p>
      {%- endif -%}

      <h1 class="collections-page__title">
        {{ section.settings.heading | default: 'collections.title' | t }}
      </h1>

      {%- if section.settings.subheading != blank -%}
        <p class="collections-page__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    {%- capture collection_cards -%}
      {%- for collection in collections -%}
        {%- if collection.all_products_count > 0 -%}
          <a href="{{ collection.url }}" class="collections-page__card">
            {%- if collection.featured_image != blank -%}
              {{
                collection.featured_image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  widths: '400, 600, 800',
                  sizes: '(min-width: 1440px) 33vw, (min-width: 768px) 50vw, 100vw',
                  alt: collection.title
                | escape
              }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag }}
            {%- endif -%}
            <div class="collections-page__card-overlay"></div>
            <p class="collections-page__card-name">{{ collection.title | escape }}</p>
          </a>
        {%- endif -%}
      {%- endfor -%}
    {%- endcapture -%}

    {%- if collection_cards != blank -%}
      <div class="collections-page__grid">{{ collection_cards }}</div>
    {%- else -%}
      <p class="collections-page__empty">{{ 'collections.empty' | t }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:general.collections_grid",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "presets": [{ "name": "t:general.collections_grid" }]
}
{% endschema %}
