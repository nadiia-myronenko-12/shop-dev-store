{%- comment -%}
  Global structured data (JSON-LD) for SEO / rich results.
  - Organization + WebSite (with SearchAction) on every page
  - BreadcrumbList on collection / product / article pages
  Product-level Product schema is emitted separately via `{{ product | structured_data }}`
  in snippets/meta-tags.liquid.
{%- endcomment -%}

{%- liquid
  assign root = request.origin | default: shop.url
-%}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ root | json }}
    {%- if settings.logo != blank %},
    "logo": {{ settings.logo | image_url: width: 512 | prepend: "https:" | json }}
    {%- endif -%}
  }
</script>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": {{ root | json }},
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "{{ root }}/search?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  }
</script>

{%- if request.page_type == 'collection'
  or request.page_type == 'product'
  or request.page_type == 'article'
-%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ root | json }}
        }
        {%- if request.page_type == "collection" and collection -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }},
            "item": {{ collection.url | prepend: root | json }}
          }
        {%- elsif request.page_type == "product" and product -%}
          {%- if collection -%}
            ,{
              "@type": "ListItem",
              "position": 2,
              "name": {{ collection.title | json }},
              "item": {{ collection.url | prepend: root | json }}
            },
            {
              "@type": "ListItem",
              "position": 3,
              "name": {{ product.title | json }},
              "item": {{ product.url | prepend: root | json }}
            }
          {%- else -%}
            ,{
              "@type": "ListItem",
              "position": 2,
              "name": {{ product.title | json }},
              "item": {{ product.url | prepend: root | json }}
            }
          {%- endif -%}
        {%- elsif request.page_type == "article" and article -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ article.title | json }},
            "item": {{ article.url | prepend: root | json }}
          }
        {%- endif -%}
      ]
    }
  </script>
{%- endif -%}
