<div
  id="shop-toast-container"
  class="shop-toast-container"
  aria-live="assertive"
  aria-atomic="true"
></div>

<style>
  .shop-toast-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 10000;
    display: flex;
    flex-direction: column;
    gap: 10px;
    pointer-events: none;
  }

  .shop-toast {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: #fff;
    border: 1px solid #dcdcdc;
    border-radius: 16px;
    padding: 14px 16px;
    min-width: 280px;
    max-width: 340px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
    pointer-events: auto;
    font-family: 'Inter', sans-serif;
    animation: shop-toast-in 0.3s cubic-bezier(0.34, 1.3, 0.64, 1) both;
  }

  .shop-toast--exit {
    animation: shop-toast-out 0.25s ease both;
  }

  @keyframes shop-toast-in {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes shop-toast-out {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(8px);
    }
  }

  .shop-toast__icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .shop-toast__icon--cart {
    background: #000;
    color: #fff;
  }

  .shop-toast__icon--wishlist {
    background: #fff0f0;
    color: #e41616;
  }

  .shop-toast__body {
    flex: 1;
    min-width: 0;
  }

  .shop-toast__title {
    font-size: 14px;
    font-weight: 600;
    color: #000;
    line-height: 1.35;
    margin-bottom: 2px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .shop-toast__desc {
    font-size: 13px;
    font-weight: 400;
    color: #535353;
    line-height: 1.4;
  }

  .shop-toast__close {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9d9d9d;
    border-radius: 6px;
    transition:
      color 0.15s ease,
      background-color 0.15s ease;
    margin-top: -2px;
  }

  .shop-toast__close:hover {
    color: #000;
    background-color: #f8f8f8;
  }

  .shop-toast__action {
    display: inline-block;
    margin-top: 6px;
    font-size: 13px;
    font-weight: 600;
    color: #000;
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
  }

  .shop-toast__action:hover {
    color: #535353;
  }

  @media (max-width: 767px) {
    .shop-toast-container {
      bottom: 16px;
      left: 16px;
      right: 16px;
    }

    .shop-toast {
      min-width: 0;
      max-width: none;
    }
  }
</style>

<script>
  window.ShopTheme = window.ShopTheme || {};

  window.ShopTheme.customer = {
    loggedIn: {% if customer %}true{% else %}false{% endif %},
    loginUrl: {{ routes.account_login_url | json }},
  };

  const icons = {
    cart: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>',
    wishlist: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>',
  };

  window.ShopTheme.showToast = function({ title, description, type, action }) {
    const container = document.getElementById('shop-toast-container');
    if (!container) return;

    const toast = document.createElement('div');
    toast.className = 'shop-toast';

    const iconEl = document.createElement('div');
    iconEl.className = `shop-toast__icon shop-toast__icon--${type}`;
    iconEl.innerHTML = icons[type] ?? icons.cart;

    const body = document.createElement('div');
    body.className = 'shop-toast__body';

    const titleEl = document.createElement('p');
    titleEl.className = 'shop-toast__title';
    titleEl.textContent = title;

    const descEl = document.createElement('p');
    descEl.className = 'shop-toast__desc';
    descEl.textContent = description;

    body.append(titleEl, descEl);

    if (action) {
      const actionLink = document.createElement('a');
      actionLink.className = 'shop-toast__action';
      actionLink.href = action.url;
      actionLink.textContent = action.text;
      body.appendChild(actionLink);
    }

    const closeBtn = document.createElement('button');
    closeBtn.className = 'shop-toast__close';
    closeBtn.setAttribute('aria-label', 'Dismiss');
    closeBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';

    toast.append(iconEl, body, closeBtn);

    function dismiss() {
      toast.classList.add('shop-toast--exit');
      toast.addEventListener('animationend', () => toast.remove(), { once: true });
    }

    closeBtn.addEventListener('click', dismiss);
    container.appendChild(toast);

    let timer = setTimeout(dismiss, 4000);
    toast.addEventListener('mouseenter', () => clearTimeout(timer));
    toast.addEventListener('mouseleave', () => { timer = setTimeout(dismiss, 2000); });
  };

  window.ShopTheme.updateCartCount = async function() {
    try {
      const { item_count: count } = await fetch('/cart.js').then(r => r.json());
      const badge = document.querySelector('.site-header__cart-badge');
      if (!badge) return;
      badge.textContent = count;
      badge.setAttribute('data-count', String(count));
    } catch (_) {}
  };

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const container = document.getElementById('shop-toast-container');
    const last = container?.lastElementChild;
    last?.querySelector('.shop-toast__close')?.click();
  });
</script>
